# =============================================================================
# Valura AI — Environment variables (copy to .env and customize)
# =============================================================================
# Never commit a filled .env file.

# --- LLM ---
# Optional: if unset or empty, get_llm_client() uses MockLLMClient (CI-safe).
OPENAI_API_KEY=

# Chat completions model. Development default keeps cost low; eval often uses gpt-4.1.
LLM_MODEL=gpt-4o-mini
# Backwards-compatible alias for older configs:
# OPENAI_MODEL=gpt-4o-mini

# --- HTTP pipeline ---
# Maximum wall-clock seconds for a single /chat SSE generator (float OK).
PIPELINE_TIMEOUT=30

# Root logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# --- Runtime ---
APP_ENV=development

# =============================================================================
# Optional — persistence / cache (not required for this demo)
# =============================================================================

# DATABASE_URL=
# REDIS_URL=
# PGVECTOR_DATABASE_URL=
