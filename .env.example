# =============================================================================
# Finsight — Environment variables (copy to .env and customize)
# =============================================================================
# IMPORTANT: never commit a filled .env file. .env is gitignored; this file is not.

# --- LLM provider (precedence: GROQ > OPENAI > SmartMockLLMClient) ---
# Get a free Groq key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: Groq model id for member agents (classifier, Agno tools). Default: llama-3.1-8b-instant
# GROQ_MODEL=llama-3.1-8b-instant
# Optional: Agno Team coordinator model on Groq. Defaults to the same as GROQ_MODEL to stay
# within free-tier TPM; set to e.g. llama-3.3-70b-versatile when you have headroom.
# GROQ_TEAM_MODEL=

# Optional fallback if GROQ_API_KEY is empty.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Generic alias picked up by both providers when their specific *_MODEL is unset.
# LLM_MODEL=

# --- HTTP pipeline ---
# Maximum wall-clock seconds for a single /chat SSE generator (float OK).
PIPELINE_TIMEOUT=30

# Agno ``Team.arun`` on Groq: retries after transient 429 / TPM (not context errors).
# AGNO_TEAM_RETRY_ATTEMPTS=2
# AGNO_TEAM_RETRY_BASE_S=18

# Minimum seconds between Yahoo Finance requests (shared HF egress IPs get 429 / Invalid Crumb if bursty).
# YFINANCE_MIN_INTERVAL_S=0.55

# When using Groq-only (no OpenAI), skip Agno multi-agent team by default to stay under TPM.
# Set to 1 to force the Agno team on Groq (may hit rate limits).
# FINSIGHT_USE_AGNO_TEAM=0

# Optional pause before Team.arun on Groq-only to reduce back-to-back bursts.
# GROQ_TEAM_PREFLIGHT_SLEEP_S=2

# Root logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# --- Runtime ---
APP_ENV=development

# --- Writable data (Docker image sets DATA_DIR=/app/data; local dev usually omits) ---
# DATA_DIR=
# REPORTS_DIR=
# REPORT_RETENTION_HOURS=72
# REPORT_MAX_TOTAL_MB=256
# REPORT_MAX_FILES=500
# REPORT_CLEANUP_INTERVAL_SEC=3600
# CORS_ORIGINS=

# =============================================================================
# Optional — persistence / cache (not required for this demo)
# =============================================================================

# Agno cross-session memory (default: under DATA_DIR as .agno_memory.db).
# FINSIGHT_MEMORY_DB=

# DATABASE_URL=
# REDIS_URL=
# PGVECTOR_DATABASE_URL=
